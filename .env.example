# ----- Azure -----
AZURE_SUBSCRIPTION_ID=00000000-0000-0000-0000-000000000000
AZURE_RESOURCE_GROUP=rg-prvendtest
AZURE_LOCATION=westus
AZURE_SECONDARY_LOCATION=eastus

# Base name used to derive resource names (3-11 chars, lowercase alphanumerics)
BASE_NAME=prvendcu

# ----- Power Platform -----
# Power Platform tenant (Microsoft Entra tenant ID hosting the PP environment)
PP_TENANT_ID=00000000-0000-0000-0000-000000000000

# Power Platform environment GUID (NOT the org URL).
# Find it in PPAC -> Environments -> your env -> Environment ID,
# or via: pac admin list
PP_ENVIRONMENT_ID=00000000-0000-0000-0000-000000000000

# Power Platform geo for the Enterprise Policy resource location.
# e.g. unitedstates, europe, australia, asia, ...
# See: https://learn.microsoft.com/power-platform/admin/regions-overview
PP_GEO=unitedstates

# Name to give the Enterprise Policy resource in Azure
ENTERPRISE_POLICY_NAME=ep-vnet-prvendcu
